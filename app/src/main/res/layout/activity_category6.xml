                    android:layout_gravity="center"
                    android:backgroundTint="@color/button_scroll"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/calc_lease"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />

            </LinearLayout>
